<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PortoVix Dashboard | Flávia P. Pissarra</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-pearl: #d8d4cf;
            --text-main: #2c1e1a;
            --mother-of-pearl: linear-gradient(120deg, #fdfbfb 0%, #ebedee 100%);
        }

        body {
            background-color: var(--bg-pearl);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            color: var(--text-main);
        }

        .header-nav {
            width: 100%;
            max-width: 1000px;
            margin-bottom: 20px;
        }

        .back-link {
            text-decoration: none;
            color: #8d807a;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .dashboard-container {
            width: 100%;
            max-width: 1000px;
            background: var(--mother-of-pearl);
            border-radius: 25px;
            padding: 20px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .info-panel {
            margin-bottom: 20px;
        }

        .info-panel h1 {
            font-size: 1.4rem;
            margin: 0 0 10px 0;
            color: #5d4037;
        }

        .info-panel p {
            font-size: 0.9rem;
            color: #5d5752;
            line-height: 1.4;
        }

        .iframe-wrapper {
            position: relative;
            padding-top: 56.25%; /* Proporção 16:9 */
            height: 0;
            overflow: hidden;
            border-radius: 15px;
            background: #fff;
        }

        .iframe-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }
    </style>
</head>
<body>

    <nav class="header-nav">
        <a href="../../index.html" class="back-link">← Return to Portfolio</a>
    </nav>

    <main class="dashboard-container">
        <section class="info-panel">
            <h1>PortoVix: Maritime Logistics Intelligence</h1>
            <p>Data analysis focused on port efficiency and cargo movement in Vitória, Espírito Santo.</p>
        </section>

        <div class="iframe-wrapper">
            <!-- Insira o link 'Publicar na Web' do seu Power BI aqui -->
            <iframe 
                title="PortoVix Dashboard" 
                src="SEU_LINK_DO_POWERBI_AQUI" 
                allowFullScreen="true">
            </iframe>
        </div>
    </main>

</body>
</html>
